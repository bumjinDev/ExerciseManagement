              "const now=new Date();const p=n=>String(n).padStart(2,'0');",
              "pm.collectionVariables.set('recruitStart', fmt(new Date(now.getTime()-3600000)));",
              "pm.collectionVariables.set('recruitEnd', fmt(new Date(now.getTime()+86400000)));",
              "pm.collectionVariables.set('performStart', fmt(new Date(now.getTime()-3600000)));",
              "pm.collectionVariables.set('performEnd', fmt(new Date(now.getTime()+86400000)));",
              "pm.collectionVariables.set('today', now.getFullYear()+'-'+p(now.getMonth()+1)+'-'+p(now.getDate()));",
              "const tm=new Date(now.getTime()+86400000);",
              "pm.collectionVariables.set('tomorrow', tm.getFullYear()+'-'+p(tm.getMonth()+1)+'-'+p(tm.getDate()));"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
