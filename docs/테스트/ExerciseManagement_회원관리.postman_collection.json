    {
      "name": "04. 회원 가입 - 유효성 실패 (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('400 Bad Request', function () { pm.response.to.have.status(400); });",
              "pm.test('pw 필드 에러 메시지 존재', function () { pm.expect(pm.response.json()).to.have.property('pw'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"tester02\",\n  \"pw\": \"1234\",\n  \"nickName\": \"테스터이\",\n  \"tel\": \"010-2222-3333\",\n  \"email\": \"tester02@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/members/join",
          "host": ["{{baseUrl}}"],
          "path": ["members", "join"]
        }
      }
    },
    {
      "name": "05. 로그인 (정상 → 302 리다이렉트 → 200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Postman 기본 설정(리다이렉트 자동 추적)이면 /members/loginSuccess 의 최종 200 응답을 받는다",
              "pm.test('최종 200 OK (loginSuccess)', function () { pm.response.to.have.status(200); });",
              "pm.test('userId 반환', function () { pm.expect(pm.response.json().userId).to.eql('tester01'); });",
              "pm.test('Authorization 쿠키 발급', function () { pm.expect(pm.cookies.has('Authorization')).to.be.true; });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userid\": \"tester01\",\n  \"password\": \"Test1234!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "06. 로그인 - 비밀번호 오류 (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });",
              "pm.test('실패 메시지 반환', function () { pm.expect(pm.response.json().message).to.include('아이디 또는 비밀번호'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userid\": \"tester01\",\n  \"password\": \"WrongPass1!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "07. 로그인 성공 확인 (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "pm.test('userId·userName 반환', function () {",
              "    var body = pm.response.json();",
              "    pm.expect(body).to.have.property('userId');",
              "    pm.expect(body).to.have.property('userName');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/members/loginSuccess",
          "host": ["{{baseUrl}}"],
          "path": ["members", "loginSuccess"]
