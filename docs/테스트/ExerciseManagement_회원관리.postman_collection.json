          "raw": "{\n  \"id\": \"admin\",\n  \"pw\": \"Test1234!\",\n  \"nickName\": \"관리자행세\",\n  \"tel\": \"010-1111-2222\",\n  \"email\": \"admin@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/members/join",
          "host": ["{{baseUrl}}"],
          "path": ["members", "join"]
        }
